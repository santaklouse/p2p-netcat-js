{
  "name": "@santaklouse/p2p-netcat",
  "version": "2.1.2",
  "description": "TCP/QUIC netcat-like CLI addressed by libp2p PeerId instead of IP",
  "type": "module",
  "workspaces": [
    "packages/core"
  ],
  "files": [
    "bin",
    "docs",
    "src",
    "README.md",
    "README.RU.md",
    "LICENSE"
  ],
  "bin": {
    "p2p-nc": "./bin/p2p-nc.js",
    "pnc": "./bin/p2p-nc.js"
  },
  "exports": {
    "./relay": {
      "types": "./src/relay.d.ts",
      "import": "./src/relay.js"
    },
  },
  "scripts": {
    "start": "node ./bin/p2p-nc.js",
    "test": "node --test",
    "lint": "node --check ./bin/p2p-nc.js && node --check ./src/cli.js && node --check ./src/node.js && node --check ./src/discovery.js && node --check ./src/relay.js && node --check ./src/session.js && node --check ./src/trystero.js && npm --prefix packages/core run lint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santaklouse/p2p-netcat-js.git"
  },
  "bugs": {
    "url": "https://github.com/santaklouse/p2p-netcat-js/issues"
  },
  "homepage": "https://github.com/santaklouse/p2p-netcat-js#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "p2p",
    "libp2p",
    "netcat",
    "peer-id",
    "ipfs",
    "quic",
    "circuit-relay"
  ],
  "author": "santaklouse",
  "license": "MIT",
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-quic": "^2.1.1",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/bootstrap": "^12.0.27",
    "@libp2p/circuit-relay-v2": "^4.2.9",
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/identify": "^4.1.10",
    "@libp2p/kad-dht": "^16.4.0",
    "@libp2p/mdns": "^12.0.27",
    "@libp2p/peer-id": "^6.0.4",
    "@libp2p/ping": "^3.1.9",
    "@libp2p/tcp": "^11.0.24",
    "@libp2p/websockets": "^10.1.17",
    "@multiformats/multiaddr": "^13.0.1",
    "@roamhq/wrtc": "^0.10.0",
    "@santaklouse/p2p-netcat-core": "^0.1.1",
    "@trystero-p2p/torrent": "^0.25.3",
    "commander": "^14.0.0",
    "libp2p": "^3.3.6"
  }
}
